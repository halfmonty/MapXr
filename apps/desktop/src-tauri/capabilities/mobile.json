{
  "$schema": "../gen/schemas/mobile-schema.json",
  "identifier": "mobile",
  "description": "Capability for the main window — Android",
  "windows": ["main"],
  "platforms": ["android"],
  "permissions": [
    "core:default",
    "opener:default",
    "core:window:default",
    "ble:default",
    "battery:default",
    "shizuku:default",
    "notification:default",
    "notification:allow-is-permission-granted",
    "notification:allow-request-permission"
  ]
}
